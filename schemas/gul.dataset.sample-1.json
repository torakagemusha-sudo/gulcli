{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "gul.dataset.sample/1",
  "title": "GUL Dataset Sample v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "entity",
    "predicate",
    "context_confidence",
    "decision",
    "confidence",
    "evidence"
  ],
  "properties": {
    "entity": {
      "type": "object",
      "required": ["kind", "id"],
      "additionalProperties": false,
      "properties": {
        "kind": {"type": "string"},
        "id": {"type": "string"}
      }
    },
    "predicate": {"$ref": "./gul.predicate-1.json"},
    "context_confidence": {"type": "number", "minimum": 0, "maximum": 1},
    "decision": {"$ref": "./gul.decision-1.json"},
    "confidence": {"type": "number", "minimum": 0, "maximum": 1},
    "evidence": {
      "type": "array",
      "items": {"type": "string"}
    },
    "extensions": {
      "type": "object",
      "additionalProperties": true
    }
  }
}
